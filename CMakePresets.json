{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "debug",
      "displayName": "Debug Build",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release Build",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "default-config",
      "inherits": "debug"
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "default-build",
      "configurePreset": "default-config"
    },
    {
      "name": "build-run",
      "configurePreset": "default-config",
      "targets": ["run"]
    }
  ],
  "workflowPresets": [
    {
      "name": "configure-build-run",
      "steps": [
        {
          "type": "configure",
          "name": "default-config"
        },
        {
          "type": "build",
          "name": "build-run"
        }
      ]
    }
  ]
}
